# DPO2U Solana — environment template
#
# Copy to .env and fill in. NEVER commit .env to git (already gitignored).

# ─── Solana Cluster ──────────────────────────────────────────────────────
# devnet | mainnet-beta
SOLANA_CLUSTER=devnet

# ~/.config/solana/id.json default; override pra usar HSM-signed wallets ou
# por-script keys
SOLANA_WALLET=

# ─── Light Protocol / Photon (Composed Stack — Fase 3) ────────────────────
# Helius API key — register at https://www.helius.dev/dashboard
# Photon Indexer is included with Helius RPC subscription.
HELIUS_API_KEY=

# Override pra self-hosted Photon (defaults to Helius public endpoint)
# PHOTON_RPC_URL=https://devnet.helius-rpc.com

# Concurrent Merkle Tree (alocada via scripts/init-cmt.ts)
# Saved automatically em scripts/cmt-config.json após init.
LIGHT_CMT_STATE_TREE=
LIGHT_CMT_STATE_QUEUE=
LIGHT_CMT_ADDRESS_TREE=
LIGHT_CMT_ADDRESS_QUEUE=

# ─── Squads v4 Multisig (Composed Stack — Fase 1) ─────────────────────────
# PDAs criados via scripts/setup-squads-multisig.ts.
# Saved em scripts/squads-config.json — esses .env vars são fallback rápido
# pro MCP server e demos.
SQUADS_GOVERNANCE_PDA=
SQUADS_TREASURY_PDA=
SQUADS_MICAR_RESERVE_PDA=
SQUADS_COMPLIANCE_AUTHORITY_PDA=
SQUADS_EMERGENCY_PDA=

# ─── Shadow Drive (Composed Stack — Fase 4) ───────────────────────────────
# Storage account ID alocado em scripts/init-shdw-storage-account.ts (1GB pre-paid).
# Cada batch de attestations de uma batch/jurisdição usa um storage account
# separado pra permitir make-immutable granular.
SHDW_STORAGE_ACCOUNT=
SHDW_GATEWAY=https://shdw-drive.genesysgo.net/

# ─── DPO2U Programs (production) ──────────────────────────────────────────
# IDs pinned em /root/dpo2u-solana/solana-programs/Anchor.toml — env vars
# servem pra CI override pra testes contra forks ou clones em dev pessoais.
COMPLIANCE_REGISTRY_PROGRAM_ID=7q19zbMMFCPSDhJhh3cfUVJstin6r1Q4dgmeDAuQERyK
COMPLIANCE_PINOCCHIO_PROGRAM_ID=FZ21S53Rn8Y6ANfccS2waCrkYWh5zfjXK3hkKU5YSkJ8
ART_VAULT_PROGRAM_ID=C7sGZFeWPxEkaGHACwqdzCcy4QkacqPLYEwEarVpidna
SP1_VERIFIER_PROGRAM_ID=5xrWphWXoFnXJh7jYt3tyWZAwX1itbyyxJQs8uumiRTW
LIGHT_SYSTEM_PROGRAM_ID=SySTEM1eSU2p4BGQfQpimFEWWSC1XDFeun3Nqzz3rT7
SQUADS_V4_PROGRAM_ID=SQDS4ej4dZndYAQiRJzRZqDPoAHTQ8R7BbfwL3GnxCk
