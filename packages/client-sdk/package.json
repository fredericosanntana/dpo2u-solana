{
  "name": "@dpo2u/client-sdk",
  "version": "0.1.0",
  "description": "TypeScript client for dpo2u-solana — build/send verified-attestation transactions from Node.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dpo2u-cli": "./dist/bin/dpo2u-cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/web3.js": "^1.98.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "typescript": "^5.3.3",
    "vitest": "^1.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
